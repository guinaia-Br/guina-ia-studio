{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "yarn install",
  "framework": "nextjs",
  "regions": ["gru1"],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": {
      "description": "Supabase Project URL (from Settings > API)",
      "required": true
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "description": "Supabase Anon/Public Key (from Settings > API)",
      "required": true
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "description": "Supabase Service Role Key (from Settings > API)",
      "required": true
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API Key (optional - uses MOCK if not provided)",
      "required": false
    }
  }
}